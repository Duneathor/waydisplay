{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "gcc-base",
      "hidden": true,
      "generator": "Unix Makefiles",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++"
      }
    },
    {
      "name": "debug",
      "displayName": "WayDisplay GCC Debug",
      "inherits": "gcc-base",
      "binaryDir": "${sourceDir}/build-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "WAYDISPLAY_BUILD_TESTS": "OFF",
        "WAYDISPLAY_RUN_TESTS_ON_BUILD": "OFF"
      }
    },
    {
      "name": "release",
      "displayName": "WayDisplay GCC Release",
      "inherits": "gcc-base",
      "binaryDir": "${sourceDir}/build-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "WAYDISPLAY_BUILD_TESTS": "OFF",
        "WAYDISPLAY_RUN_TESTS_ON_BUILD": "OFF"
      }
    },
    {
      "name": "profile",
      "displayName": "WayDisplay GCC PGO instrumentation",
      "inherits": "gcc-base",
      "binaryDir": "${sourceDir}/build-native",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Profile",
        "WAYDISPLAY_PGO_DATA_DIR": "${sourceDir}/build-pgo-data",
        "WAYDISPLAY_BUILD_TESTS": "OFF",
        "WAYDISPLAY_RUN_TESTS_ON_BUILD": "OFF"
      }
    },
    {
      "name": "native",
      "displayName": "WayDisplay GCC native optimized",
      "inherits": "gcc-base",
      "binaryDir": "${sourceDir}/build-native",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Native",
        "WAYDISPLAY_PGO_DATA_DIR": "${sourceDir}/build-pgo-data",
        "WAYDISPLAY_BUILD_TESTS": "OFF",
        "WAYDISPLAY_RUN_TESTS_ON_BUILD": "OFF"
      }
    },
    {
      "name": "tests-base",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "WAYDISPLAY_BUILD_TESTS": "ON",
        "WAYDISPLAY_RUN_TESTS_ON_BUILD": "ON"
      },
      "inherits": "gcc-base"
    },
    {
      "name": "tests",
      "displayName": "WayDisplay dependency-light unit tests",
      "inherits": "tests-base",
      "binaryDir": "${sourceDir}/build-tests",
      "cacheVariables": {
        "WAYDISPLAY_BUILD_CLIENT_SDL": "OFF",
        "WAYDISPLAY_BUILD_WLROOTS_SERVER": "OFF"
      }
    },
    {
      "name": "tests-core",
      "displayName": "WayDisplay core tests without optional backends",
      "inherits": "tests-base",
      "binaryDir": "${sourceDir}/build-tests-core",
      "cacheVariables": {
        "WAYDISPLAY_BUILD_CLIENT_SDL": "OFF",
        "WAYDISPLAY_BUILD_WLROOTS_SERVER": "OFF",
        "WAYDISPLAY_ENABLE_AUDIO": "OFF",
        "WAYDISPLAY_ENABLE_H264_SERVER_ENCODER": "OFF",
        "WAYDISPLAY_ENABLE_H265_SERVER_ENCODER": "OFF",
        "WAYDISPLAY_ENABLE_H264_CLIENT_DECODER": "OFF",
        "WAYDISPLAY_ENABLE_H265_CLIENT_DECODER": "OFF",
        "WAYDISPLAY_ENABLE_VAAPI_CLIENT_DECODER": "OFF"
      }
    },
    {
      "name": "tests-warnings",
      "displayName": "WayDisplay strict warning build",
      "inherits": "tests-core",
      "binaryDir": "${sourceDir}/build-tests-warnings",
      "cacheVariables": {
        "WAYDISPLAY_RUN_TESTS_ON_BUILD": "OFF",
        "WAYDISPLAY_WARNINGS_AS_ERRORS": "ON"
      }
    },
    {
      "name": "tests-asan-ubsan",
      "displayName": "WayDisplay ASan and UBSan tests",
      "inherits": "tests-core",
      "binaryDir": "${sourceDir}/build-tests-asan-ubsan",
      "cacheVariables": {
        "WAYDISPLAY_RUN_TESTS_ON_BUILD": "OFF",
        "CMAKE_C_FLAGS": "-fsanitize=address,undefined -fno-omit-frame-pointer",
        "CMAKE_CXX_FLAGS": "-fsanitize=address,undefined -fno-omit-frame-pointer",
        "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=address,undefined",
        "CMAKE_SHARED_LINKER_FLAGS": "-fsanitize=address,undefined"
      }
    },
    {
      "name": "tests-tsan",
      "displayName": "WayDisplay ThreadSanitizer tests",
      "inherits": "tests-core",
      "binaryDir": "${sourceDir}/build-tests-tsan",
      "cacheVariables": {
        "WAYDISPLAY_RUN_TESTS_ON_BUILD": "OFF",
        "CMAKE_C_FLAGS": "-fsanitize=thread -fno-omit-frame-pointer",
        "CMAKE_CXX_FLAGS": "-fsanitize=thread -fno-omit-frame-pointer",
        "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=thread",
        "CMAKE_SHARED_LINKER_FLAGS": "-fsanitize=thread"
      }
    },
    {
      "name": "tests-codecs",
      "displayName": "WayDisplay FFmpeg and VAAPI codec tests",
      "inherits": "tests-base",
      "binaryDir": "${sourceDir}/build-tests-codecs",
      "cacheVariables": {
        "WAYDISPLAY_BUILD_CLIENT_SDL": "OFF",
        "WAYDISPLAY_BUILD_WLROOTS_SERVER": "OFF",
        "WAYDISPLAY_ENABLE_AUDIO": "OFF",
        "WAYDISPLAY_ENABLE_H264_SERVER_ENCODER": "ON",
        "WAYDISPLAY_ENABLE_H265_SERVER_ENCODER": "ON",
        "WAYDISPLAY_ENABLE_H264_CLIENT_DECODER": "ON",
        "WAYDISPLAY_ENABLE_H265_CLIENT_DECODER": "ON",
        "WAYDISPLAY_ENABLE_VAAPI_CLIENT_DECODER": "ON",
        "WAYDISPLAY_REQUIRE_CODEC_TESTS": "ON",
        "WAYDISPLAY_WARNINGS_AS_ERRORS": "ON"
      }
    },
    {
      "name": "tests-wlroots",
      "displayName": "WayDisplay wlroots tests with Xwayland",
      "inherits": "tests-base",
      "binaryDir": "${sourceDir}/build-tests-wlroots",
      "cacheVariables": {
        "WAYDISPLAY_BUILD_CLIENT_SDL": "OFF",
        "WAYDISPLAY_BUILD_WLROOTS_SERVER": "ON",
        "WAYDISPLAY_ENABLE_XWAYLAND": "ON",
        "WAYDISPLAY_ENABLE_AUDIO": "OFF",
        "WAYDISPLAY_ENABLE_H264_SERVER_ENCODER": "OFF",
        "WAYDISPLAY_ENABLE_H265_SERVER_ENCODER": "OFF",
        "WAYDISPLAY_ENABLE_H264_CLIENT_DECODER": "OFF",
        "WAYDISPLAY_ENABLE_H265_CLIENT_DECODER": "OFF",
        "WAYDISPLAY_ENABLE_VAAPI_CLIENT_DECODER": "OFF",
        "WAYDISPLAY_REQUIRE_WLROOTS_TESTS": "ON"
      }
    },
    {
      "name": "tests-wlroots-no-xwayland",
      "displayName": "WayDisplay wlroots tests without Xwayland",
      "inherits": "tests-wlroots",
      "binaryDir": "${sourceDir}/build-tests-wlroots-no-xwayland",
      "cacheVariables": {
        "WAYDISPLAY_ENABLE_XWAYLAND": "OFF"
      }
    },
    {
      "name": "tests-full",
      "displayName": "WayDisplay full optional-backend test build",
      "inherits": "tests-base",
      "binaryDir": "${sourceDir}/build-tests-full",
      "cacheVariables": {
        "WAYDISPLAY_REQUIRE_RUNTIME_TARGETS": "ON"
      }
    },
    {
      "name": "tests-coverage",
      "displayName": "WayDisplay GCC coverage tests",
      "inherits": "tests-core",
      "binaryDir": "${sourceDir}/build-tests-coverage",
      "cacheVariables": {
        "WAYDISPLAY_RUN_TESTS_ON_BUILD": "OFF",
        "CMAKE_C_FLAGS": "--coverage -O0 -g",
        "CMAKE_CXX_FLAGS": "--coverage -O0 -g",
        "CMAKE_EXE_LINKER_FLAGS": "--coverage",
        "CMAKE_SHARED_LINKER_FLAGS": "--coverage"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "profile",
      "configurePreset": "profile"
    },
    {
      "name": "native",
      "configurePreset": "native"
    },
    {
      "name": "tests",
      "configurePreset": "tests"
    },
    {
      "name": "tests-core",
      "configurePreset": "tests-core"
    },
    {
      "name": "tests-warnings",
      "configurePreset": "tests-warnings"
    },
    {
      "name": "tests-asan-ubsan",
      "configurePreset": "tests-asan-ubsan"
    },
    {
      "name": "tests-tsan",
      "configurePreset": "tests-tsan"
    },
    {
      "name": "tests-codecs",
      "configurePreset": "tests-codecs"
    },
    {
      "name": "tests-wlroots",
      "configurePreset": "tests-wlroots"
    },
    {
      "name": "tests-wlroots-no-xwayland",
      "configurePreset": "tests-wlroots-no-xwayland"
    },
    {
      "name": "tests-full",
      "configurePreset": "tests-full"
    },
    {
      "name": "tests-coverage",
      "configurePreset": "tests-coverage"
    }
  ],
  "testPresets": [
    {
      "name": "tests",
      "configurePreset": "tests",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "tests-core",
      "configurePreset": "tests-core",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "tests-warnings",
      "configurePreset": "tests-warnings",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "tests-asan-ubsan",
      "configurePreset": "tests-asan-ubsan",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "tests-tsan",
      "configurePreset": "tests-tsan",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "tests-codecs",
      "configurePreset": "tests-codecs",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "tests-wlroots",
      "configurePreset": "tests-wlroots",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "tests-wlroots-no-xwayland",
      "configurePreset": "tests-wlroots-no-xwayland",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "tests-full",
      "configurePreset": "tests-full",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "tests-coverage",
      "configurePreset": "tests-coverage",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
